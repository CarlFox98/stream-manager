# Twitch API credentials
# Get these from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# OBS WebSocket (optional) — enables real scene/stream/record status instead
# of just "is obs64.exe running". In OBS: Tools > WebSocket Server Settings >
# Enable WebSocket server, then copy the password shown there.
# Requires: pip install websocket-client
# OBS_WEBSOCKET_PASSWORD=your_obs_websocket_password
# OBS_WEBSOCKET_HOST=localhost
# OBS_WEBSOCKET_PORT=4455
